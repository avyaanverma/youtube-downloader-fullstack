{
  "manifest_version": 3,
  "name": "YouLaugh",
  "version": "1.0.2",
  "description": "This is a YouTube information extractor that helps you load video images, titles, and descriptions on YouTube.",
  "permissions": ["activeTab", "downloads", "cookies"],
  "host_permissions": [
    "https://youtube-downloader-fullstack-2.onrender.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://*.youtube.com/*",
    "https://*.google.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "youlaugh@avyaanverma.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*", "https://www.youtube.com/shorts/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouLaugh"
  }
}