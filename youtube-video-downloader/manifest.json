{
  "manifest_version": 2,
  "name": "YouLaugh",
  "version": "1.0",
  "description": "Youtube Video Downloader",
  
  "permissions": ["activeTab"],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
  "default_popup": "popup.html",
  "default_title": "YouLaugh"
}
}